# Aiven MySQL (shared host; each service uses its own database name)
AIVEN_MYSQL_HOST=
AIVEN_MYSQL_PORT=3306
AIVEN_MYSQL_USER=
AIVEN_MYSQL_PASSWORD=

# Per-service database names
USER_DB_NAME=ecommerce_user_db
PRODUCT_DB_NAME=ecommerce_product_db
INVENTORY_DB_NAME=ecommerce_inventory_db
ORDER_DB_NAME=ecommerce_order_db
PAYMENT_DB_NAME=ecommerce_payment_db
NOTIFICATION_DB_NAME=ecommerce_notification_db

# JWT (min 32 characters for HS256)
JWT_SECRET=
JWT_EXPIRATION_MS=86400000

# Infrastructure
CONFIG_SERVER_URL=http://localhost:8888
EUREKA_SERVER_URL=http://localhost:8761/eureka/

# API Gateway
GATEWAY_PORT=8080
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Frontend
VITE_API_BASE_URL=http://localhost:8080

# Payment simulation (set to true to force failures for testing)
PAYMENT_FORCE_FAIL=false

# Dev seed data
SEED_DATA_ENABLED=true

# Inter-service authentication (Feign calls between microservices)
INTERNAL_SERVICE_KEY=dev-internal-key
